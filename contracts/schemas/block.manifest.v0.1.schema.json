{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackcat.darkmesh/schemas/block.manifest.v0.1.schema.json",
  "title": "BlackCat Block Manifest v0.1",
  "type": "object",
  "required": [
    "schema",
    "blockId",
    "version",
    "kind",
    "runtime",
    "ui",
    "logic",
    "contracts",
    "security",
    "integrity"
  ],
  "properties": {
    "schema": { "const": "blackcat.block.manifest.v0.1" },
    "blockId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["feature", "layout", "widget"] },
    "runtime": {
      "type": "object",
      "required": ["client", "entry"],
      "properties": {
        "client": { "type": "string", "enum": ["esm"] },
        "entry": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "required": ["markup", "style", "slots"],
      "properties": {
        "markup": { "type": "string", "minLength": 1 },
        "style": { "type": "string", "minLength": 1 },
        "slots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "logic": {
      "type": "object",
      "required": ["stateMachine", "events"],
      "properties": {
        "stateMachine": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "contracts": {
      "type": "object",
      "required": ["gatewayActions", "requiresSiteBinding", "requiresWorkerSignature"],
      "properties": {
        "gatewayActions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "requestSchemaRef", "responseSchemaRef", "idempotency"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "requestSchemaRef": { "type": "string", "minLength": 1 },
              "responseSchemaRef": { "type": "string", "minLength": 1 },
              "idempotency": { "type": "string", "enum": ["required", "optional"] }
            },
            "additionalProperties": false
          }
        },
        "requiresSiteBinding": { "type": "boolean" },
        "requiresWorkerSignature": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "required": ["forbiddenCapabilities"],
      "properties": {
        "forbiddenCapabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "required": ["bundleSha256", "signature"],
      "properties": {
        "bundleSha256": { "type": "string", "pattern": "^sha256-[A-Fa-f0-9]{64}$" },
        "signature": {
          "type": "object",
          "required": ["algo", "signerRef", "sig"],
          "properties": {
            "algo": { "type": "string", "enum": ["ed25519"] },
            "signerRef": { "type": "string", "minLength": 1 },
            "sig": { "type": "string", "minLength": 16 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
