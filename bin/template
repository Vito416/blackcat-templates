#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" != "readme" ]]; then
  echo "Usage: template readme <Name> <Description>" >&2
  exit 1
fi

NAME="${2:-}"
DESCRIPTION="${3:-}"
if [[ -z "$NAME" || -z "$DESCRIPTION" ]]; then
  echo "Usage: template readme <Name> <Description>" >&2
  exit 1
fi

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG="${BLACKCAT_TEMPLATES_CONFIG:-$DIR/../config/example.templates.json}"

node --import "$DIR/../node_modules/tsx/dist/loader.mjs" "$DIR/../src/cli.ts" "$CONFIG" template:run module_readme "{\"MODULE_NAME\":\"$NAME\",\"DESCRIPTION\":\"$DESCRIPTION\"}"
